{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Requirement Metadata",
  "type": "object",
  "required": ["id", "title", "project", "stage"],
  "properties": {
    "id": { "type": "string", "pattern": "^\\d{4}-\\d{2}-[a-z0-9-]+$" },
    "title": { "type": "string" },
    "project": { "type": "string" },
    "stage": {
      "type": "string",
      "enum": [
        "需求启动",
        "上下文收集",
        "需求定义",
        "方案设计",
        "实现与测试",
        "验收与知识沉淀"
      ]
    },
    "owner": { "type": "string" }
  },
  "additionalProperties": true
}

